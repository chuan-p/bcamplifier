{
  "manifest_version": 3,
  "name": "Bandcamplifier",
  "version": "0.1.176",
  "description": "Improve the Bandcamp feed with release metadata, track playback, wishlist actions, and purchase shortcuts.",
  "homepage_url": "https://github.com/chuan-p/bcamplifier",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://bandcamp.com/*",
    "https://*.bandcamp.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "scripts": [
      "extension.background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://bandcamp.com/feed*",
        "https://bandcamp.com/*/feed*",
        "https://bandcamp.com/album/*",
        "https://bandcamp.com/track/*",
        "https://*.bandcamp.com/album/*",
        "https://*.bandcamp.com/track/*"
      ],
      "js": [
        "extension.content.js",
        "bcamplifier.user.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{87e7e243-a29e-4f97-9315-1cfd4c115a00}",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo",
          "websiteContent"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
